# CCSHUB Environment Configuration

# Application
VITE_APP_TITLE="CCSHUB - Central Coast Section Athletics"
VITE_BASE_PATH="/ccshub/"

# API Configuration (for future backend integration)
# VITE_API_URL=https://api.ccshub.example.com
# VITE_API_TIMEOUT=10000

# Feature Flags
# VITE_ENABLE_ANALYTICS=false
# VITE_ENABLE_PWA=false

# External Services
# VITE_MAXPREPS_API_KEY=your_maxpreps_key
# VITE_HUDL_API_KEY=your_hudl_key

# Development
# VITE_DEV_PORT=5173
# VITE_ENABLE_DEBUG=false

# Analytics (Optional)
# VITE_ANALYTICS_ID=your_analytics_id

# Social Media
# VITE_TWITTER_HANDLE=@ccshub
# VITE_INSTAGRAM_HANDLE=@ccshub
